rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: renders
    // Document ID: auto-generated
    // Fields:
    //   - userId: string (required) - The UID of the user who generated the script.
    //   - prompt: string (required) - The user's original text prompt.
    //   - repos: list (required) - The list of repository names mixed for this generation.
    //   - js5Code: string (required) - The generated JavaScript code for the JS5 art.
    //   - createdAt: timestamp (required) - When the render was created.
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        ((request.auth.token.email == "marygray.art@gmail.com" && request.auth.token.email_verified == true) ||
         (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'));
    }

    function isValidRender(data) {
      return data.keys().hasAll(['userId', 'prompt', 'repos', 'js5Code', 'createdAt']) &&
             data.userId is string &&
             data.prompt is string && data.prompt.size() < 5000 &&
             data.repos is list && data.repos.size() < 50 &&
             data.js5Code is string && data.js5Code.size() < 100000 &&
             data.createdAt is timestamp;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /renders/{renderId} {
      // Users can only read their own renders
      allow read: if isOwner(resource.data.userId) || isAdmin();
      
      // Users can only create renders for themselves
      allow create: if isOwner(request.resource.data.userId) && isValidRender(request.resource.data);
      
      // Renders are immutable
      allow update, delete: if isAdmin();
    }

    match /test/connection {
      allow read: if true;
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow write: if isAdmin();
    }
  }
}
