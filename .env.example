# OPENROUTER_API_KEY: Required for LLM generation via OpenRouter.
# Sign up free at https://openrouter.ai and create an API key.
# OpenRouter gives you access to Qwen, DeepSeek, Llama, Mistral and many more models.
OPENROUTER_API_KEY="MY_OPENROUTER_API_KEY"

# LLM_MODEL: The model to use for main code generation (optional).
# Defaults to qwen/qwen-2.5-coder-32b-instruct if not set.
# Other great options: deepseek/deepseek-chat-v3-0324, meta-llama/llama-3.3-70b-instruct
LLM_MODEL="qwen/qwen-2.5-coder-32b-instruct"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# GITHUB_TOKEN: Personal Access Token for GitHub API.
# This is a private secret used by the server to proxy GitHub requests.
# Configure this in the Secrets panel in AI Studio.
GITHUB_TOKEN=
